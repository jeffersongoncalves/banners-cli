{
    "name": "jeffersongoncalves/banners-cli",
    "description": "CLI tool to generate banner images using beyondcode/banners service.",
    "keywords": ["cli", "banner", "image", "generator", "laravel-zero"],
    "homepage": "https://github.com/jeffersongoncalves/banners-cli",
    "type": "project",
    "license": "MIT",
    "authors": [
        {
            "name": "Jefferson Goncalves",
            "email": "jeffersongoncalves@users.noreply.github.com"
        }
    ],
    "require": {
        "php": "^8.2"
    },
    "require-dev": {
        "guzzlehttp/guzzle": "^7.10",
        "laravel-zero/framework": "^12.0.2",
        "laravel/pint": "^1.25.1",
        "mockery/mockery": "^1.6.12",
        "pestphp/pest": "^3.8.4|^4.1.2"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "config": {
        "preferred-install": "dist",
        "sort-packages": true,
        "optimize-autoloader": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "bin": ["builds/banners"]
}
